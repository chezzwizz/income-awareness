{\n  "manifest_version": 2,\n  "name": "Income Awareness Plugin",\n  "version": "1.0",\n  "description": "A plugin to promote income awareness.",\n  "permissions": ["activeTab"],\n  "browser_action": {\n    "default_popup": "popup.html",\n    "default_icon": "icon.png"\n  },\n  "background": {\n    "scripts": ["background.js"],\n    "persistent": false\n  },\n  "content_scripts": [\n    {\n      "matches": ["<all_urls>"],\n      "js": ["content.js"]\n    }\n  ]\n}