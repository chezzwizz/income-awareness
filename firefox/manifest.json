{
  "manifest_version": 2,
  "name": "Income Awareness Plugin",
  "version": "1.0",
  "description": "A Firefox extension to promote awareness about income sharing.",
  "icons": {
    "48": "icons/icon.png"
  },
  "permissions": [
    "activeTab"
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon.png"
  },
  "background": {
    "scripts": ["background.js"]
  }
}