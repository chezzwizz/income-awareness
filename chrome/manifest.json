{\n    "manifest_version": 3,\n    "name": "Income Awareness",\n    "version": "1.0",\n    "description": "A Chrome extension for income awareness.",\n    "permissions": ["activeTab"],\n    "action": {\n        "default_popup": "popup.html",\n        "default_icon": {\n            "16": "icon16.png",\n            "48": "icon48.png",\n            "128": "icon128.png"\n        }\n    },\n    "background": {\n        "service_worker": "background.js"\n    },\n    "content_scripts": [\n        {\n            "matches": ["<all_urls>"],\n            "js": ["content.js"]\n        }\n    ],\n    "web_accessible_resources": [\n        {\n            "resources": ["icon*.png"],\n            "matches": ["<all_urls>"]\n        }\n    ]\n}